{
    "$schema": "https://unpkg.com/knip@5/schema-jsonc.json",
    "workspaces": {
        ".": {
            "entry": ["scripts/*.ts", "adlc.config.ts", ".claude/hooks/post-compact.mjs"],
            "ignoreDependencies": ["netlify-cli"]
        },
        "apps/host": {
            "entry": ["src/index.tsx", "rsbuild.build.ts", "rsbuild.dev.ts"],
            "ignoreDependencies": ["@tailwindcss/postcss", "@workleap/browserslist-config", "tailwindcss"]
        },
        "apps/storybook": {
            "ignoreDependencies": [
                "@packages/components",
                "@packages/api",
                "@squide/firefly",
                "@squide/firefly-storybook",
                "@tanstack/react-query",
                "@workleap/logging",
                "react-router"
            ]
        },
        "apps/storybook-management": {
            "ignoreDependencies": [
                "@packages/components",
                "@packages/api",
                "@squide/firefly",
                "@squide/firefly-storybook",
                "@tanstack/react-query",
                "@workleap/logging",
                "react-router"
            ]
        },
        "apps/storybook-watering": {
            "ignoreDependencies": [
                "@packages/components",
                "@packages/api",
                "@squide/firefly",
                "@squide/firefly-storybook",
                "@tanstack/react-query",
                "@workleap/logging",
                "react-router"
            ]
        },
        "modules/management": {
            "entry": ["src/inventory/index.ts", "src/account/index.ts"]
        },
        "modules/watering": {
            "entry": ["src/today/index.ts"]
        },
        "packages/components": {
            "entry": ["rslib.build.ts", "rslib.dev.ts", "postcss.config.mjs", "src/index.ts"],
            "ignoreDependencies": ["@tailwindcss/postcss"],
            "includeEntryExports": false
        },
        "adlc": {
            "entry": ["rslib.build.ts", "src/cli.ts", "src/index.ts"],
            "ignoreDependencies": ["@rsbuild/core"],
            "includeEntryExports": false
        },
        "apps/storybook-packages": {
            "ignoreDependencies": [
                "@packages/components",
                "@packages/core-module",
                "@packages/api",
                "@squide/firefly",
                "@squide/firefly-storybook",
                "@tanstack/react-query",
                "@workleap/logging",
                "msw",
                "react-router"
            ]
        }
    }
}
