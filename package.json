{
    "name": "workspace-root",
    "version": "0.0.0",
    "private": true,
    "description": "Workspace root.",
    "license": "Apache-2.0",
    "author": "Patrick Lafrance",
    "type": "module",
    "scripts": {
        "build": "turbo run build",
        "dev-app": "turbo run dev --filter=@apps/host",
        "dev-management": "cross-env MODULES=management pnpm dev-app",
        "dev-watering": "cross-env MODULES=watering pnpm dev-app",
        "dev-storybook-management": "turbo run dev --filter=@apps/storybook-management",
        "dev-storybook-watering": "turbo run dev --filter=@apps/storybook-watering",
        "dev-storybook-packages": "turbo run dev --filter=@apps/storybook-packages",
        "dev-storybook": "turbo run dev --filter=@apps/storybook",
        "build-host": "turbo run build --filter=@apps/host",
        "build-storybook": "turbo run build-storybook --filter=@apps/storybook",
        "serve-host": "turbo run serve-build --filter=@apps/host",
        "serve-storybook": "turbo run serve-storybook --filter=@apps/storybook",
        "install-playwright": "tsx scripts/install-playwright.ts",
        "test": "turbo run test",
        "test-harness": "vitest run --config agent-hooks/vitest.config.ts",
        "lint": "turbo run lint --continue",
        "typecheck": "tsgo",
        "lint-check": "oxlint --deny-warnings --react-plugin --import-plugin --jsx-a11y-plugin --react-perf-plugin --promise-plugin --vitest-plugin",
        "lint-fix": "oxlint --fix --deny-warnings --react-plugin --import-plugin --jsx-a11y-plugin --react-perf-plugin --promise-plugin --vitest-plugin",
        "format-check": "oxfmt --check",
        "format-fix": "oxfmt",
        "knip": "knip",
        "syncpack": "syncpack lint",
        "clean": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf dist storybook-static .turbo .rslib node_modules/.cache",
        "reset": "pnpm run --sequential \"/^reset:.*/\"",
        "reset:clean": "pnpm clean",
        "reset:delete-node-modules": "pnpm -r --parallel --include-workspace-root exec pnpm dlx rimraf node_modules pnpm-lock.yaml",
        "list-outdated-deps": "pnpm outdated -r --format list",
        "update-outdated-deps": "pnpm run --sequential \"/^update-outdated-deps:.*/\"",
        "update-outdated-deps:update-versions": "pnpm update -r --latest",
        "update-outdated-deps:update-peers": "syncpack fix"
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "@typescript/native-preview": "7.0.0-dev.20260401.1",
        "@workleap/typescript-configs": "4.0.0",
        "agent-browser": "0.23.4",
        "cross-env": "10.1.0",
        "knip": "6.2.0",
        "netlify-cli": "24.9.0",
        "oxfmt": "0.43.0",
        "oxlint": "1.58.0",
        "syncpack": "14.3.0",
        "tsx": "4.21.0",
        "turbo": "2.9.3",
        "vitest": "4.1.2"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10"
    },
    "packageManager": "pnpm@10.30.1"
}
